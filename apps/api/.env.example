# --- Database Configuration (Postgres) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=hitchly_db
# Neon / Supabase / other remote hosts: TLS required (or set PGSSLMODE=require)
# DB_SSL=true

# --- API Configuration (server uses PORT; API_URL must match) ---
PORT=4000
API_URL=http://localhost:4000

# --- Better Auth (BETTER_AUTH_URL must match API_URL) ---
# Generate a real secret in prod (e.g., using `openssl rand -base64 32`)
BETTER_AUTH_SECRET="replace_with_secure_random_string"
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_BASE_PATH=/api/auth

# --- Email Configuration ---
GMAIL_USER="example@gmail.com"
GMAIL_APP_PASS="your_app_specific_password"

# --- Development (Expo Go) ---
# Set to false to allow ride requests without a payment method (Stripe is not available in Expo Go).
# Only use for local testing; leave unset or true in production.
# REQUIRE_PAYMENT_METHOD=false